{
  "services": {
    "app-frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "app-backend": {
      "root": "backend",
      "entrypoint": "main.py",
      "framework": "fastapi"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": { "service": "app-backend" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "app-frontend" }
    }
  ]
}
