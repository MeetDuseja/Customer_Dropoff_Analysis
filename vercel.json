{
  "services": {
    "app-frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "app-backend": {
      "root": "backend",
      "entrypoint": "main.py",
      "framework": "fastapi"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}
